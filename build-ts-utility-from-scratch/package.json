{
  "name": "build-ts-utility-from-scratch",
  "version": "0.1.0",
  "private": true,
  "description": "A compiler-checked TypeScript utility type koan workbook.",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "test": "npm run check",
    "check:koan": "tsc --noEmit --strict --target ES2022 --module ESNext --moduleResolution Bundler --skipLibCheck",
    "check:example": "tsc --noEmit --strict --target ES2022 --module ESNext --moduleResolution Bundler --skipLibCheck src/examples/solved-pick.example.ts"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
