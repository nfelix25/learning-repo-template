{
  "name": "typed-event-practice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Test-driven TypeScript koans for typed event and communication patterns.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test",
    "scratch": "tsx"
  },
  "keywords": [
    "typescript",
    "events",
    "koans"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
